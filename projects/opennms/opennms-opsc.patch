+       if_svc.id AS if_svc_id,
+       if_svc.ifindex AS if_svc_ifindex,
+       if_svc.status AS if_svc_status
+FROM (((public.node_categories n
+    LEFT JOIN public.ipinterface ip_if ON ((ip_if.nodeid = n.nodeid)))
