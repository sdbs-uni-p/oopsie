diff --git a/build.gradle.kts b/build.gradle.kts
new file mode 100644
index 000000000..7acfa1563
--- /dev/null
+++ b/build.gradle.kts
@@ -0,0 +1,96 @@
+plugins {
+    id("java-library")
+    id("io.freefair.lombok") version "8.11"
+    id("org.checkerframework") version "0.6.56"
+}
+
+val eisopVersion = "3.49.3-eisop1"
+
+// specify opslogdir here
+extra["opslogdir"] = "{{{opslogdir}}}"
+
+allprojects {
+    repositories {
+        mavenLocal()
+        mavenCentral()
+    }
+}
+
+subprojects {
+    apply(plugin = "java-library")
+    apply(plugin = "io.freefair.lombok")
+    apply(plugin = "org.checkerframework")
+
+    tasks.register("prepareKotlinBuildScriptModel"){}
+
+    dependencies {
+        api("log4j:log4j:1.2.13")
+        api("commons-cli:commons-cli:1.2")
+        runtimeOnly("postgresql:postgresql:8.0-318.jdbc3")
+
+        // Importing dependency management BOM
+        implementation(platform("org.springframework.boot:spring-boot-dependencies:2.7.5"))
+
+        // Dependencies
+        implementation("commons-dbcp:commons-dbcp:1.4")
+        implementation("net.sourceforge.htmlunit:htmlunit:2.70.0")
+        implementation("com.google.code.gson:gson:2.10.1")
+        implementation("com.google.inject:guice:5.1.0")
+        testImplementation("com.github.stefanbirkner:system-lambda:1.1.0")
+
+        // Logging dependencies
+        implementation("org.slf4j:slf4j-api")
+        implementation("ch.qos.logback:logback-classic")
+        implementation("ch.qos.logback:logback-core")
+
+        implementation("com.h2database:h2")
+
+        // checker dependencies
+        compileOnly("io.github.eisop:checker-qual:${eisopVersion}")
+        testCompileOnly("io.github.eisop:checker-qual:${eisopVersion}")
+        checkerFramework("io.github.eisop:checker:${eisopVersion}")
+
+        compileOnly("io.github.eisop:opsc:0.0.1-SNAPSHOT")
+        checkerFramework("io.github.eisop:opsc:0.0.1-SNAPSHOT")
+    }
+
+    checkerFramework {
+        suppressLombokWarnings = false
+    }
+
+    // resolution strategy: always use eisop checker framework
+    configurations.all {
+        resolutionStrategy {
+            eachDependency {
+                if (requested.group == "org.checkerframework") {
+                    // replace org.checkerframework with io.github.eisop
+                    useTarget("io.github.eisop:${requested.name}:${eisopVersion}")
+                }
+            }
+        }
+    }
+//
+//    configure<CheckerFrameworkExtension> {
+//        checkers = listOf(
+//            "io.github.eisop.opsc.OpsChecker"
+//        )
+//        extraJavacArgs = listOf(
+//            "-Awarns",
+//            "-AnonNullStringsConcatenation=true",
+////            "-AdbUrl=jdbc:postgresql://localhost:5432/java-design-patterns",
+//            "-AdbUser=postgres",
+//            "-AdbPassword=postgres"
+//        )
+//    }
+
+//    // set dbUrl to .../<subproject-name>
+//    tasks.withType<JavaCompile> {
+//        val subprojectName = project.name.replace("-", "_")
+//        options.compilerArgs.add("-AdbUrl=jdbc:postgresql://localhost:5432/$subprojectName")
+//    }
+
+}
+
+group = "io.github.xu8117"
+version = "0.1-SNAPSHOT"
+description = "java-design-patterns"
\ No newline at end of file
