+--
+-- Name: node_alarm_status; Type: VIEW; Schema: public; Owner: opennms
+--
+
+CREATE VIEW public.node_alarm_status AS
+SELECT node.nodeid,
+       COALESCE(( SELECT max(
+                                 CASE
+                                     WHEN ((alarms.severity IS NULL) OR (alarms.severity < 3)) THEN 3
+                                     ELSE alarms.severity
+                                     END) AS max
+                  FROM public.alarms
+                  WHERE (alarms.nodeid = node.nodeid)), 3) AS max_alarm_severity,
+       COALESCE(( SELECT max(
+                                 CASE
+                                     WHEN ((alarms.severity IS NULL) OR (alarms.severity < 3)) THEN 3
+                                     ELSE alarms.severity
+                                     END) AS max
+                  FROM public.alarms
+                  WHERE ((alarms.nodeid = node.nodeid) AND (alarms.alarmacktime IS NULL))), 3) AS max_alarm_severity_unack,
+       ( SELECT count(alarms.alarmid) AS count
+         FROM public.alarms
+         WHERE ((alarms.nodeid = node.nodeid) AND (alarms.alarmacktime IS NULL))) AS alarm_count_unack,
+       ( SELECT count(*) AS count
+         FROM public.alarms
+         WHERE (alarms.nodeid = node.nodeid)) AS alarm_count
+FROM public.node;
+
+
+ALTER TABLE public.node_alarm_status OWNER TO opennms;
